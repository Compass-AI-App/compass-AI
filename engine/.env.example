# Compass Engine Configuration
# Copy to .env and fill in your values

# LLM Provider (required for BYOK mode)
ANTHROPIC_API_KEY=sk-ant-...

# Compass Cloud (used when not in BYOK mode)
# COMPASS_CLOUD_URL=https://api.compass.dev
# COMPASS_AUTH_TOKEN=...

# GitHub (optional, for code connector)
GITHUB_TOKEN=ghp_...
